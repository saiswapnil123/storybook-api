PORT=3000
NODE_ENV=development

# Docker local development — "postgres" is the compose service hostname.
# For Supabase or other hosted databases, replace with your connection strings.
DATABASE_URL="postgresql://postgres:postgres@postgres:5432/storybook"

# Used by Prisma for migrations (direct session-mode connection, no pgbouncer).
# For local Docker this is the same as DATABASE_URL.
# For Supabase: use the session-mode pooler URL (port 5432).
DIRECT_URL="postgresql://postgres:postgres@postgres:5432/storybook"

AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET=storybook-api-bucket
AWS_S3_PREFIX=uploads
